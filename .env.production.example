# --- Backend Configuration ---
DEBUG=false
# Replace with your production domain (e.g., ["https://your-frontend.vercel.app"])
CORS_ORIGINS=["*"]

# Database (Persistent volume mapped to /app/data)
DATABASE_URL=sqlite:///./data/hair_multica.db

# Storage (Persistent volume mapped to /app/uploads)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
# Replace with your production API URL + /uploads
STORAGE_BASE_URL=https://your-api-domain.com/uploads

# LLM Providers (Required for AI features)
LLM_PROVIDER=openai
LLM_API_KEY=your-production-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_IMAGE_MODEL=dall-e-3
LLM_TEXT_MODEL=gpt-4o

# --- Frontend Configuration ---
# Use this when deploying the frontend (e.g., on Vercel)
# NEXT_PUBLIC_API_BASE_URL=https://your-api-domain.com/api
