# =============================================================================
# Environment Variables — 录音文字收益最大化系统
# Copy this file to `.env` and fill in real values before running docker-compose.
# NEVER commit `.env` to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=production
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-256-bit-random-secret-key-here

# ---------------------------------------------------------------------------
# PostgreSQL Database
# ---------------------------------------------------------------------------
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=audioprofit
DATABASE_URL=postgresql://appuser:change-me-strong-password@postgres:5432/audioprofit

# ---------------------------------------------------------------------------
# Qdrant Vector Database
# ---------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=audio_chunks

# ---------------------------------------------------------------------------
# LLM / AI APIs
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Optional: Alternative LLM providers
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# AZURE_OPENAI_API_KEY=your-azure-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
NODE_ENV=production
VITE_API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Observability (Optional)
# ---------------------------------------------------------------------------
# SENTRY_DSN=https://your-sentry-dsn-here
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
