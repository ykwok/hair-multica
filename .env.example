# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Backend
DEBUG=false
CORS_ORIGINS=["*"]

# Database
DATABASE_URL=sqlite:///./data/hair_multica.db

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_BASE_URL=http://localhost:8000/uploads

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEXT_MODEL=gpt-4o
LLM_VISION_MODEL=gpt-4o
LLM_IMAGE_MODEL=dall-e-3

# fal.ai (for HD hairstyle generation)
FAL_API_KEY=your-fal-api-key
FAL_MODEL_ID=fal-ai/instant-id
FAL_PREVIEW_MODEL_ID=fal-ai/fast-sdxl
FAL_TIMEOUT_SECONDS=120

# Aliyun 通义万相 (fallback provider)
ALIYUN_API_KEY=your-aliyun-api-key
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_IMAGE_MODEL=wanx-v1
ALIYUN_TEXT_MODEL=qwen-vl-max

# VolcEngine 豆包 (fallback provider)
VOLCENGINE_API_KEY=your-volcengine-api-key
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_IMAGE_MODEL=doubao-image
VOLCENGINE_TEXT_MODEL=doubao-vision-pro
